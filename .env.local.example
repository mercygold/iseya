# ISEYA local environment template.
# Copy to .env.local and replace placeholders. Do not commit real secrets.

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY

# Candidate Stripe price IDs
STRIPE_PRICE_PLUS_USD=
STRIPE_PRICE_PLUS_NGN=
STRIPE_PRICE_PLUS_GBP=
STRIPE_PRICE_PLUS_CAD=
STRIPE_PRICE_PRO_MONTHLY_USD=
STRIPE_PRICE_PRO_MONTHLY_NGN=
STRIPE_PRICE_PRO_MONTHLY_GBP=
STRIPE_PRICE_PRO_MONTHLY_CAD=
STRIPE_PRICE_PRO_ANNUAL_USD=
STRIPE_PRICE_PRO_ANNUAL_NGN=
STRIPE_PRICE_PRO_ANNUAL_GBP=
STRIPE_PRICE_PRO_ANNUAL_CAD=

# Recruiter Stripe price IDs
STRIPE_PRICE_RECRUITER_QUARTERLY_USD=
STRIPE_PRICE_RECRUITER_QUARTERLY_NGN=
STRIPE_PRICE_RECRUITER_QUARTERLY_GBP=
STRIPE_PRICE_RECRUITER_QUARTERLY_CAD=
STRIPE_PRICE_RECRUITER_ANNUAL_USD=
STRIPE_PRICE_RECRUITER_ANNUAL_NGN=
STRIPE_PRICE_RECRUITER_ANNUAL_GBP=
STRIPE_PRICE_RECRUITER_ANNUAL_CAD=

# Email provider
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
RESEND_FROM_EMAIL=hello@jormp.com

# SMTP fallback / transactional email reference
SMTP_HOST=REPLACE_WITH_SMTP_HOST
SMTP_PORT=587
SMTP_USER=hello@jormp.com
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM_EMAIL=hello@jormp.com

# Analytics / feature flags
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ENABLE_INSTITUTION_ACCESS=false
